# QuickBooks Online MCP Server Configuration

# OAuth 2.0 Credentials (from https://developer.intuit.com/app/developer/qbo/docs/develop/authentication-and-authorization)
QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here

# OAuth 2.0 Refresh Token (obtained after initial OAuth flow)
QB_REFRESH_TOKEN=your_refresh_token_here

# Company (Realm) ID — found in QuickBooks URL or dashboard
QB_REALM_ID=your_realm_id_here

# Environment: production or sandbox (default: production)
# QB_ENVIRONMENT=production

# Transport (optional — default: stdio)
# MCP_TRANSPORT=http
# MCP_HTTP_PORT=3000
